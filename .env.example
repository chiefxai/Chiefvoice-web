# ============================================================
# .env — ChiefVoice Web Realtime
# ============================================================

# Gemini API key — needs Gemini 2.0 Flash Live access
# Get at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Port (default 3000)
PORT=3000

# Supabase configuration for recordings & call history
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# No Exotel credentials needed — this is browser-only
